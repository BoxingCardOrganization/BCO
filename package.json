{
  "name": "bco-platform",
  "version": "1.0.0",
  "description": "Boxing Card Organization - Digital Fighter Cards Platform",
  "main": "app.js",
  "scripts": {
    "chain": "npx hardhat node",
    "start": "node app.js",
    "dev": "concurrently \"npm run chain\" \"npm run start\"",
    "compile": "npx hardhat compile",
    "test": "npx hardhat test",
    "deploy:local": "npx hardhat run scripts/deployLocal.js --network localhost",
    "valuations:run": "node scripts/computeWeeklyValuations.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "node-fetch": "^2.7.0",
    "concurrently": "^8.2.2",
    "ethers": "^6.8.1"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^3.0.0",
    "hardhat": "^2.17.1"
  },
  "keywords": ["blockchain", "nft", "boxing", "trading-cards"],
  "author": "BCO Team",
  "license": "MIT"
}